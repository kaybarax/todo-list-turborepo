{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Bun",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "composite": false,
    "strict": true,
    "lib": ["ESNext"],
    "types": ["bun"]
  }
}
