# ===========================================================================
# API Gateway — Environment Configuration
# ===========================================================================
# Copy this file to .env and adjust values for your local environment.
# All variables are optional unless marked [REQUIRED].

# ── Server ────────────────────────────────────────────────────────────────
PORT=3003                              # Listening port (default: 3003)
PUBLIC_API_PREFIX=/api/v1              # Public API prefix (default: /api/v1)
NODE_ENV=development                   # Runtime environment (default: development)

# ── Upstreams ─────────────────────────────────────────────────────────────
NEST_API_URL=http://localhost:3001     # NestJS API upstream URL (default: http://localhost:3001)
BUN_API_URL=http://localhost:3002      # Bun/Elysia API upstream URL (default: http://localhost:3002)

# ── Auth [REQUIRED] ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-real-secret  # ⚠️ JWT signing secret — MUST be set to a non-empty value

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000      # Allowed CORS origin (default: http://localhost:3000)

# ── Proxy ─────────────────────────────────────────────────────────────────
PROXY_TIMEOUT_MS=10000                 # Upstream request timeout in ms (default: 10000)

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true                # Enable/disable rate limiting (default: true; accepts true/false/1/0)