# Web Application Environment Variables
# Copy this file to .env.local for local development.
# Store these as Vercel environment variables per Vercel environment.

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Blockchain public configuration
NEXT_PUBLIC_POLYGON_RPC_URL=http://localhost:8545
NEXT_PUBLIC_SOLANA_RPC_URL=http://localhost:8899
NEXT_PUBLIC_POLKADOT_RPC_URL=ws://localhost:9944
NEXT_PUBLIC_MOONBEAM_RPC_URL=http://localhost:9944
NEXT_PUBLIC_BASE_RPC_URL=http://localhost:8545
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Feature flags
NEXT_PUBLIC_ENABLE_BLOCKCHAIN=true
NEXT_PUBLIC_ENABLE_PWA=true

# OpenTelemetry
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Logging
NEXT_PUBLIC_LOG_LEVEL=debug
