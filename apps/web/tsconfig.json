{
  "extends": "@todo/config-ts/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@/*": ["./src/*"],
      "@todo/services": ["../../packages/services/src"],
      "@todo/services/*": ["../../packages/services/src/*"],
      "@todo/ui-web": ["../../packages/ui-web/src"],
      "@todo/ui-web/*": ["../../packages/ui-web/src/*"],
      "@todo/utils": ["../../packages/utils/src"],
      "@todo/utils/*": ["../../packages/utils/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", ".next"],
  "references": [{ "path": "../../packages/ui-web" }, { "path": "../../packages/services" }]
}
