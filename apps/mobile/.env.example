# Mobile Application Environment Variables (Expo)
# Copy this file to .env.local for local development.
# Use EXPO_PUBLIC_ prefix for variables that need to be available in the app.

# API URLs
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_WS_URL=ws://localhost:3001

# Blockchain public configuration
EXPO_PUBLIC_POLYGON_RPC_URL=http://localhost:8545
EXPO_PUBLIC_SOLANA_RPC_URL=http://localhost:8899
EXPO_PUBLIC_POLKADOT_RPC_URL=ws://localhost:9944
EXPO_PUBLIC_MOONBEAM_RPC_URL=http://localhost:9944
EXPO_PUBLIC_BASE_RPC_URL=http://localhost:8545

# Third-party services
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Feature flags
EXPO_PUBLIC_ENABLE_BLOCKCHAIN=true

# Logging
EXPO_PUBLIC_LOG_LEVEL=debug
