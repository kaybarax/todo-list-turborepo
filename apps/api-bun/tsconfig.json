{
  "extends": "@todo/config-ts/bun.json",
  "compilerOptions": {
    "baseUrl": "./",
    "skipLibCheck": true,
    "types": ["bun"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["src/*"],
      "@todo/*": ["../../packages/*/src"]
    }
  },
  "include": ["src/**/*", "test/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
